generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id           String       @id @default(cuid())
  name         String?
  email        String       @unique
  password     String?
  businessName String?
  phone        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  accounts     Account[]
  sessions     Session[]
  vehicles     Vehicle[]
  inspections  Inspection[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Vehicle {
  id           String       @id @default(cuid())
  make         String
  model        String
  year         Int
  licensePlate String       @unique
  color        String
  vin          String?
  notes        String?
  ownerId      String
  owner        User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  inspections  Inspection[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Inspection {
  id               String            @id @default(cuid())
  vehicleId        String
  vehicle          Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  userId           String
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  type             String            // PRE_RENTAL | POST_RENTAL
  status           String            @default("PENDING") // PENDING | IN_PROGRESS | COMPLETED
  renterName       String?
  renterPhone      String?
  renterEmail      String?
  rentalStart      DateTime?
  rentalEnd        DateTime?
  notes            String?
  aiReport         String?
  preInspectionId  String?
  images           InspectionImage[]
  damages          Damage[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model InspectionImage {
  id           String     @id @default(cuid())
  inspectionId String
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  url          String
  angle        String     // front | rear | left | right | left_front | right_front | left_rear | right_rear | interior | roof | other
  createdAt    DateTime   @default(now())
}

model Damage {
  id             String     @id @default(cuid())
  inspectionId   String
  inspection     Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  type           String     // scratch | dent | crack | paint_chip | broken | missing | other
  severity       String     // minor | moderate | severe
  location       String
  description    String
  imageUrl       String?
  isNew          Boolean    @default(false)
  estimatedCost  Float?
  createdAt      DateTime   @default(now())
}
